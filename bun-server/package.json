{
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun src/server.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:new": "dbmate new",
    "db:up": "dbmate up",
    "db:down": "dbmate down",
    "db:dump": "dbmate dump",
    "db:status": "dbmate status",
    "db:drop": "dbmate drop",
    "db:types": "kysely-codegen --out-file src/db/types.ts",
    "db:migrate": "bun run db:up && bun run db:types",
    "db:reset": "bun run db:drop && bun run db:migrate",
    "test": "bun test",
    "test:db:up": "dbmate -e TEST_DATABASE_URL up",
    "test:db:down": "dbmate -e TEST_DATABASE_URL down",
    "test:db:status": "dbmate -e TEST_DATABASE_URL status",
    "test:db:reset": "dbmate -e TEST_DATABASE_URL drop && bun run test:db:up",
    "test:prepare": "bun run test:db:reset",
    "test:ci": "bun run test:prepare && bun test"
  },
  "dependencies": {
    "@elysia/openapi": "^1.4.15",
    "elysia": "^1.4.28",
    "kysely": "^0.29.2",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/bun": "^1.3.14",
    "@types/pg": "^8.20.0",
    "dbmate": "^2.33.0",
    "globals": "^17.6.0",
    "kysely-codegen": "^0.20.0",
    "typescript-eslint": "^8.60.0"
  }
}
